PORT=3000
CLIENT_URL=http://localhost:3000

# Starknet network: mainnet | sepolia
STARKNET_NETWORK=mainnet

# Starknet RPC (Alchemy, Blast, Lava, etc.)
RPC_URL=https://starknet-mainnet.g.alchemy.com/starknet/version/rpc/v0_10/YOUR_KEY

# Privy (from console.privy.io)
PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# AVNU Paymaster (sponsored = dApp pays gas)
PAYMASTER_URL=https://starknet.paymaster.avnu.fi
PAYMASTER_API_KEY=your_avnu_paymaster_api_key
